ARG VERSION=11.5.2

# gosu for dropping to grafana user after chown (Railway volumes mount as root)
FROM tianon/gosu:1.16 AS gosu

FROM grafana/grafana-oss:${VERSION}

USER root
COPY --from=gosu /usr/local/bin/gosu /usr/local/bin/gosu

# Provision datasources and dashboards
COPY datasources /etc/grafana/provisioning/datasources
COPY provisioning/dashboards /etc/grafana/provisioning/dashboards
COPY dashboards /etc/grafana/provisioning/dashboards/dashboards

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["grafana-server"]