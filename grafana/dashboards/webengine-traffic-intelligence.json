      "targets": [
        {
          "expr": "sum by (host) (count_over_time({project_name=\"webengine\",service_name=~\"$service_name\",host=~\"$host\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" [$__range]))",
