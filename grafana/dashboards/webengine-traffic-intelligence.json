        "x": 0,
        "y": 38
      },
      "targets": [
        {
          "expr": "topk(20, sum by (remote_addr) (count_over_time({project_name=\"webengine\",service_name=~\"$service_name\",host=~\"$host\",log_type=\"http\"} | logfmt [$__range])))",
          "refId": "A",
          "legendFormat": "{{remote_addr}}"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 16,
      "type": "piechart",
      "title": "HTTP Status Class Mix (2xx/3xx/4xx/5xx)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 38
      },
      "targets": [
        {
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | regexp \"status=(?P<http_status>[0-9]{3})\" | http_status=~\"2..\" [$__range]))",
          "refId": "A",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | regexp \"status=(?P<http_status>[0-9]{3})\" | http_status=~\"3..\" [$__range]))",
