          "expr": "sum by (host) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [1h]))",
          "refId": "A",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
