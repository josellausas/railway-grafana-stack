{
  "title": "Webengine Traffic Intelligence",
  "uid": "webengine-traffic-intel",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service_name",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "grafana_lokiq"
        },
        "query": "label_values({project_name=\"webengine\"}, service_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "grafana_lokiq"
        },
        "query": "label_values({project_name=\"webengine\",service_name=~\"${service_name:regex}\"}, host)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Domain Traffic Trend (req/s)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (host) (rate({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [5m]))",
          "refId": "A",
          "legendFormat": "{{host}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests (selected range)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Status Code Mix",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (http_status) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | regexp \"status=(?P<http_status>[0-9]{3})\" [$__range]))",
          "refId": "A",
          "legendFormat": "HTTP {{http_status}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Domain Traffic Volume (selected range)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [$__range]))",
          "refId": "A",
          "legendFormat": "{{host}}",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "showValue": "auto",
        "stacking": "none",
        "barWidth": 0.9,
        "groupWidth": 0.7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Domain Traffic Share",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [$__range]))",
          "refId": "A",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Top 10 Host + Endpoint (all traffic)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (host, uri) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [$__range])))",
          "refId": "A",
          "legendFormat": "{{host}} {{uri}}",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Traffic Split: Normal vs Suspicious",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class!=\"suspicious\" [$__range]))",
          "refId": "A",
          "legendFormat": "Legit"
        },
        {
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" [$__range]))",
          "refId": "B",
          "legendFormat": "Suspicious (traffic_class)"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "404 Share of All Traffic",
      "datasource": {
        "type": "__expr__",
        "uid": "__expr__"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt [$__range]))",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "grafana_lokiq"
          },
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | regexp \"status=(?P<http_status>[0-9]{3})\" | http_status=\"404\" [$__range]))",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "__expr__",
            "uid": "__expr__"
          },
          "expression": "$B / $A",
          "refId": "C",
          "type": "math"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Suspicious Request Rate by Domain",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (host) (rate({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" [5m]))",
          "refId": "A",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "heatmap",
      "title": "Bot-target Suspicious Density Heatmap",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "sum(count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" | endpoint_class=\"bot_target\" [5m]))",
          "refId": "A",
          "legendFormat": "bot-target suspicious events"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Top Bot-target Source IPs Over Time",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "topk(10, sum by (remote_addr) (rate({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" | endpoint_class=\"bot_target\" [5m])))",
          "refId": "A",
          "legendFormat": "{{remote_addr}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Top Bot-target Endpoints (suspicious)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "expr": "topk(25, sum by (uri) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" | endpoint_class=\"bot_target\" [$__range])))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 13,
      "type": "table",
      "title": "Top Suspicious User Agents",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 30
      },
      "targets": [
        {
          "expr": "topk(20, sum by (user_agent) (count_over_time({project_name=\"webengine\",service_name=~\"${service_name:regex}\",host=~\"${host:regex}\",log_type=\"http\"} | logfmt | traffic_class=\"suspicious\" [$__range])))",
          "refId": "A",
          "legendFormat": "{{user_agent}}"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
