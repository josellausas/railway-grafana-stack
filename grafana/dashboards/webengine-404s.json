{
  "title": "Webengine 404s",
  "uid": "webengine-404s",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service_name",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "grafana_lokiq"
        },
        "query": "label_values({project_name=\"webengine\"}, service_name)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": ["$__all"]
        }
      },
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "grafana_lokiq"
        },
        "query": "label_values({project_name=\"webengine\",service_name=~\"$service_name\"}, host)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": ["$__all"]
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top 20 404 URIs (24h)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "topk(20, sum by (uri) (count_over_time({project_name=\"webengine\",service_name=~\"$service_name\",host=~\"$host\",log_type=\"http\"} | json | httpStatus=404 [24h])))",
          "refId": "A",
          "legendFormat": "{{uri}}"
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Most active IPs (404s, 24h)",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "topk(20, sum by (srcIp) (count_over_time({project_name=\"webengine\",service_name=~\"$service_name\",host=~\"$host\",log_type=\"http\"} | json | httpStatus=404 [24h])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "404 rate over time",
      "datasource": {
        "type": "loki",
        "uid": "grafana_lokiq"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate({project_name=\"webengine\",service_name=~\"$service_name\",host=~\"$host\",log_type=\"http\"} | json | httpStatus=404 [5m]))",
          "refId": "A",
          "legendFormat": "404/s"
        }
      ]
    }
  ]
}
